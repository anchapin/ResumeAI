{
  "name": "resumeai-saas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze-bundle": "npm run build && node scripts/analyze-bundle.cjs",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:a11y": "vitest tests/a11y --run",
    "test:a11y:watch": "vitest tests/a11y",
    "a11y:scan": "node scripts/a11y-scan.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:visual": "playwright test --project=visual-testing",
    "test:visual:ui": "playwright test --project=visual-testing --ui",
    "test:visual:update": "playwright test --project=visual-testing --update-snapshots",
    "test:visual:report": "playwright show-report",
    "test:flaky": "node scripts/detect-flaky-tests.cjs",
    "test:flaky:report": "node scripts/detect-flaky-tests.cjs --runs 3 --threshold 0.3 --paths ./tests",
    "test:performance": "node scripts/test-performance.mjs",
    "deps:unused": "node scripts/detect-unused-deps.mjs",
    "deps:heavy": "node scripts/detect-heavy-deps.mjs",
    "build:performance": "node scripts/build-performance.mjs",
    "deps:n1": "node scripts/detect-n-plus-1.mjs",
    "docs": "typedoc --out docs --entryPoints components/ pages/ utils/ hooks/ --excludeNotDocumented --excludeInternal --theme default",
    "lint": "eslint . --ext .ts,.tsx --no-cache",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "duplicate:check": "jscpd --threshold 5 src/ resume-api/"
  },
  "dependencies": {
    "@sentry/react": "^10.43.0",
    "@tiptap/extension-placeholder": "^3.20.2",
    "@tiptap/extension-text-align": "^3.20.2",
    "@tiptap/extension-underline": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "dompurify": "^3.3.3",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lz-string": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-toastify": "^4.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "axe-core": "^4.11.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.0.8",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.11",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "overrides": {
    "serialize-javascript": "7.0.3"
  }
}
