# ResumeAI Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================
# Frontend Configuration
# ============================================================

# API URL for the Resume API service
VITE_API_URL=http://127.0.0.1:8000

# API Key for authentication (matches MASTER_API_KEY in resume-api/.env)
RESUMEAI_API_KEY=rai_your_master_api_key_here

# ============================================================
# Resume API Configuration (Server)
# ============================================================

# Application Settings
DEBUG=false
APP_NAME=Resume AI
APP_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000

# ============================================================
# API Authentication
# ============================================================

# Set to false to disable API key authentication (for development)
REQUIRE_API_KEY=true

# Master API key for ResumeAI frontend (keep secret in production)
# Generate with: python -c "import secrets; print('rai_' + secrets.token_urlsafe(32))"
MASTER_API_KEY=rai_your_master_api_key_here

# Additional API keys for 3rd party developers (comma-separated)
# Format: rai_key1...,rai_key2...
# API_KEYS=

# ============================================================
# AI Configuration
# ============================================================

# AI Provider: openai, claude, or gemini
AI_PROVIDER=openai

# Optional: Specify a custom model (e.g., gpt-4o-mini, claude-3-5-sonnet-20241022, gemini-1.5-flash)
# AI_MODEL=

# AI Provider API Keys (at least one required for AI tailoring)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# CORS Configuration
# ============================================================

# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Rate Limiting Configuration
# ============================================================

# Set to false to disable rate limiting (for development)
ENABLE_RATE_LIMITING=true

# Rate limits for different endpoints (format: <limit>/<period>)
RATE_LIMIT_PDF=10/minute
RATE_LIMIT_TAILOR=30/minute
RATE_LIMIT_VARIANTS=60/minute

# ============================================================
# Database (Optional - SQLite used by default)
# ============================================================

# DATABASE_URL=sqlite:///./resumeai.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# ============================================================
# LinkedIn Import (Optional)
# ============================================================

# LinkedIn profile scraper API key (optional feature)
# LINKEDIN_SCRAPER_API_KEY=your_linkedin_api_key_here
