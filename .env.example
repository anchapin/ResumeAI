# Resume API Configuration
# API URL for the Resume API service
VITE_API_URL=http://127.0.0.1:8000

# API Key for authentication (matches MASTER_API_KEY in resume-api/.env)
RESUMEAI_API_KEY=rai_your_master_api_key_here

# GitHub OAuth Configuration
# Create OAuth App at https://github.com/settings/developers
# Application name: ResumeAI
# Homepage URL: https://yourdomain.com
# Authorization callback URL: https://api.yourdomain.com/github/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_CALLBACK_URL=https://api.resumeai.example.com/github/callback

# LinkedIn OAuth Configuration (Optional)
# Create OAuth App at https://www.linkedin.com/developers/apps
# Authorized redirect URL: http://localhost:5173 (for development)
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
