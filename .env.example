################################################################################
# RESUMEAI ENVIRONMENT CONFIGURATION
#
# IMPORTANT: This file documents all required and optional environment variables.
# DO NOT commit actual secrets or tokens to version control.
#
# Setup Instructions:
# For frontend: cp .env.frontend.example .env.local
# For backend:  cp .env.backend.example resume-api/.env
# For Docker:   cp .env.docker.example .env
#
# Or use the combined .env.example for quick setup (all-in-one reference).
#
# See individual .env.*.example files for detailed documentation.
#
################################################################################

################################################################################
# QUICK START - All-in-One Configuration
################################################################################
# Copy this entire file to .env.local for quick local development.
# For production, use the split files above for better organization.
#
# Required for local development:
# - VITE_API_URL (from frontend)
# - RESUMEAI_API_KEY (from frontend)  
# - At least one AI provider (OpenAI, Claude, or Gemini)
# - MASTER_API_KEY (from backend - must match frontend)
#
################################################################################

################################################################################
# FRONTEND CONFIGURATION
# Copy to .env.local: cp .env.frontend.example .env.local
################################################################################

## API Configuration
# URL of the Resume API backend
# - Development: http://localhost:8000 (local)
# - Production: https://api.resumeai.com (deployed)
VITE_API_URL=http://127.0.0.1:8000

## API Authentication
# Master API key for frontend → backend authentication
# REQUIRED: Must match MASTER_API_KEY in resume-api/.env
# Generate: openssl rand -hex 32 (for production)
# Example: rai_abc123def456ghi789jkl012
RESUMEAI_API_KEY=rai_your_master_api_key_here

## AI Provider Configuration (Frontend)
# Optional: Can also be configured in backend
# Options: openai, claude, gemini
# If not set, falls back to backend AI_PROVIDER setting
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=sk-...

## GitHub OAuth Configuration
# REQUIRED for social login feature
# Setup: https://github.com/settings/developers
#   1. Create new OAuth App
#   2. Application name: ResumeAI
#   3. Homepage URL: https://yourdomain.com
#   4. Authorization callback URL: https://api.yourdomain.com/github/callback
#   5. Generate Client Secret
#
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=https://api.resumeai.example.com/github/callback

## LinkedIn OAuth Configuration
# OPTIONAL: Social login feature
# Setup: https://www.linkedin.com/developers/apps
#   1. Create new application
#   2. Authorized redirect URL: http://localhost:5173 (dev) or https://yourdomain.com (prod)
#   3. Get Client ID and Client Secret
#
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

################################################################################
# BACKEND CONFIGURATION
# Copy to resume-api/.env: cp .env.backend.example resume-api/.env
################################################################################

## Server Configuration
# HOST: Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
# PORT: Server port (default: 8000)
# DEBUG: Debug mode (true/false) - NEVER true in production
HOST=0.0.0.0
PORT=8000
DEBUG=false

## AI Configuration
# REQUIRED: At least one provider must be configured
#
# OpenAI Configuration
# - Requires: OPENAI_API_KEY
# - Model: gpt-4o (recommended), gpt-4-turbo, gpt-3.5-turbo
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
#
# Anthropic (Claude) Configuration
# - Requires: ANTHROPIC_API_KEY
# - Model: claude-3-opus, claude-3-sonnet, claude-3-haiku
# AI_PROVIDER=claude
# AI_MODEL=claude-3-opus-20240229
# ANTHROPIC_API_KEY=sk-ant-...
#
# Google Gemini Configuration
# - Requires: GEMINI_API_KEY
# - Model: gemini-pro, gemini-1.5-pro
# AI_PROVIDER=gemini
# GEMINI_API_KEY=...

## API Authentication
# REQUIRED: Master API key for production deployments
# Generate: python -c "import secrets; print('rai_' + secrets.token_hex(32))"
# MASTER_API_KEY=rai_your_master_api_key_here
#
# OPTIONAL: Comma-separated list of additional API keys for 3rd-party integrations
# API_KEYS=rai_third_party_key1,rai_third_party_key2
#
# OPTIONAL: Set to false during development to disable auth (NOT recommended in production)
# REQUIRE_API_KEY=true

## Database Configuration (if using database in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/resumeai
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

## Redis Configuration (if using caching)
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password_here

## Email Configuration (if using email notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here
# SMTP_FROM_EMAIL=noreply@resumeai.com
# SMTP_FROM_NAME=ResumeAI

## Logging Configuration
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT: json, text
# LOG_FILE: Path to log file (optional)
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/var/log/resumeai/api.log

## Security Configuration
# JWT_SECRET: Secret key for JWT token signing
# IMPORTANT: This must be set and remain constant across server restarts
# If this changes, all existing authentication tokens will be invalidated
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REQUIRED for production (fails fast if missing)
# JWT_SECRET=your_jwt_secret_here
#
# CORS_ORIGINS: Allowed origins for cross-origin requests
# - Development: ["http://localhost:5173", "http://localhost:3000"]
# - Production: ["https://resumeai.com"]
# CORS_ORIGINS=http://localhost:5173
#
# ALLOWED_HOSTS: Hostnames allowed to access API
# ALLOWED_HOSTS=localhost,127.0.0.1,api.resumeai.com
#
# JWT_EXPIRY_HOURS: JWT token expiry time
# JWT_EXPIRY_HOURS=24
#
# REFRESH_TOKEN_EXPIRY_DAYS: Refresh token expiry time
# REFRESH_TOKEN_EXPIRY_DAYS=7

## Feature Flags
# ENABLE_SOCIAL_LOGIN=true
# ENABLE_PDF_GENERATION=true
# ENABLE_VARIANT_GENERATION=true

################################################################################
# DEPLOYMENT CONFIGURATION
# Copy to .env: cp .env.docker.example .env
################################################################################

## Docker Configuration
# Used when running in Docker containers
# DOCKER_ENV=production
# REGISTRY_URL=docker.io
# IMAGE_TAG=latest

## Kubernetes Configuration (if using K8s)
# KUBECONFIG=/root/.kube/config
# NAMESPACE=resumeai

################################################################################
# NOTES ON SECRET MANAGEMENT
################################################################################

# Do NOT share secrets via:
# - Git commits or pull requests
# - Slack, email, or chat
# - Screenshots or logs
# - Issue descriptions or comments

# DO share secrets via:
# - GitHub Secrets (for CI/CD)
# - AWS Secrets Manager
# - HashiCorp Vault
# - 1Password/LastPass (team vault)
# - Encrypted handoff or secure password manager

# For team members:
# 1. Request secrets from tech lead via secure channel
# 2. Store in .env.local (never commit)
# 3. Run application locally to test
# 4. Rotate secrets every 90 days (production)

# For CI/CD:
# 1. Store secrets in GitHub Secrets
# 2. Reference in workflows: ${{ secrets.SECRET_NAME }}
# 3. Never log secrets in CI output
# 4. Use separate secrets for staging/production

################################################################################
# REQUIRED VARIABLES CHECKLIST
################################################################################

# Development (minimum to run locally):
# - VITE_API_URL
# - RESUMEAI_API_KEY
# - At least one AI provider (OpenAI recommended)

# Production (required for deployment):
# - All development variables
# - MASTER_API_KEY (strong random value)
# - JWT_SECRET (constant across restarts, required for token persistence)
# - DEBUG=false
# - REQUIRE_API_KEY=true
# - Proper CORS_ORIGINS configured
# - Database URL (if using database)
# - Email configuration (if sending emails)

# For GitHub/LinkedIn OAuth:
# - GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET
# - GITHUB_CALLBACK_URL (must match GitHub app settings)
# - (Optional) LINKEDIN_CLIENT_ID + LINKEDIN_CLIENT_SECRET
VITE_REQUEST_SIGNING_SECRET=your_secret_here
