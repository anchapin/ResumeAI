/**
 * Simple manual test for storage utilities
 * This can be run in the browser console to verify functionality
 */

import { saveResumeData, loadResumeData, clearResumeData, hasSavedResumeData, getStoredDataSize } from './storage';
import { SimpleResumeData } from '../types';
import logger, { storageLogger } from './logger';

// Test data
const testResumeData: SimpleResumeData = {
  name: "Test User",
  email: "test@example.com",
  phone: "+1 (555) 123-4567",
  location: "Test City, TS",
  role: "Test Role",
  experience: [
    {
      id: 'test-1',
      company: 'Test Company',
      role: 'Test Position',
      startDate: 'Jan 2020',
      endDate: 'Present',
      current: true,
      description: 'Test description',
      tags: ['Test', 'Skill']
    }
  ]
};

/**
 * Run all storage tests
 */
export function runStorageTests() {
  storageLogger.info('=== Running Storage Tests ===\n');

  // Test 1: Clear any existing data
  storageLogger.info('Test 1: Clearing existing data...');
  try {
    clearResumeData();
    storageLogger.info('✓ Data cleared successfully');
  } catch (error) {
    storageLogger.error('✗ Failed to clear data:', error);
  }

  // Test 2: Check if data exists (should be false)
  storageLogger.info('\nTest 2: Checking for saved data...');
  const hasData = hasSavedResumeData();
  storageLogger.info(hasData ? '✗ Found data when expected none' : '✓ No data found as expected');

  // Test 3: Save resume data
  storageLogger.info('\nTest 3: Saving resume data...');
  try {
    saveResumeData(testResumeData);
    storageLogger.info('✓ Data saved successfully');
  } catch (error) {
    storageLogger.error('✗ Failed to save data:', error);
    return;
  }

  // Test 4: Check if data exists (should be true)
  storageLogger.info('\nTest 4: Checking for saved data...');
  const hasDataAfterSave = hasSavedResumeData();
  storageLogger.info(hasDataAfterSave ? '✓ Data found as expected' : '✗ No data found after save');

  // Test 5: Load resume data
  storageLogger.info('\nTest 5: Loading resume data...');
  try {
    const loadedData = loadResumeData();
    if (!loadedData) {
      storageLogger.error('✗ No data loaded');
      return;
    }

    // Verify data integrity
    const nameMatch = loadedData.name === testResumeData.name;
    const emailMatch = loadedData.email === testResumeData.email;
    const expCountMatch = loadedData.experience?.length === testResumeData.experience.length;

    storageLogger.info(nameMatch ? '✓ Name matches' : '✗ Name mismatch');
    storageLogger.info(emailMatch ? '✓ Email matches' : '✗ Email mismatch');
    storageLogger.info(expCountMatch ? '✓ Experience count matches' : '✗ Experience count mismatch');

    storageLogger.info('\nLoaded data:', JSON.stringify(loadedData, null, 2));
  } catch (error) {
    storageLogger.error('✗ Failed to load data:', error);
  }

  // Test 6: Check data size
  storageLogger.info('\nTest 6: Checking stored data size...');
  const size = getStoredDataSize();
  storageLogger.info(`✓ Data size: ${size} bytes (${(size / 1024).toFixed(2)} KB)`);

  // Test 7: Update and reload
  storageLogger.info('\nTest 7: Updating and reloading...');
  const updatedData = { ...testResumeData, name: "Updated User" };
  try {
    saveResumeData(updatedData);
    const reloadedData = loadResumeData();
    const nameMatches = reloadedData?.name === "Updated User";
    storageLogger.info(nameMatches ? '✓ Update persisted correctly' : '✗ Update failed to persist');
  } catch (error) {
    storageLogger.error('✗ Update test failed:', error);
  }

  // Cleanup
  storageLogger.info('\nTest 8: Cleanup - clearing test data...');
  try {
    clearResumeData();
    storageLogger.info('✓ Cleanup complete');
  } catch (error) {
    storageLogger.error('✗ Cleanup failed:', error);
  }

  storageLogger.info('\n=== Storage Tests Complete ===');
}

// Export for manual testing in browser console
if (typeof window !== 'undefined') {
  (window as any).runStorageTests = runStorageTests;
  storageLogger.info('Storage tests loaded. Run runStorageTests() to execute.');
}
