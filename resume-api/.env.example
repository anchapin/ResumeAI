# Resume API Environment Configuration

# Application Settings
DEBUG=false
APP_NAME=Resume API
APP_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000

# API Authentication
# Set to false to disable API key authentication (for development)
REQUIRE_API_KEY=true
# Master API key for ResumeAI frontend (keep secret in production)
MASTER_API_KEY=rai_1234567890abcdef1234567890abcdef
# Additional API keys for 3rd party developers (comma-separated)
# API_KEYS=rai_xyz...,rai_abc...,rai_test_key...

# AI Configuration
# Options: openai, claude, gemini
AI_PROVIDER=openai
# Optional: Specify a custom model (e.g., gpt-4o-mini, claude-3-5-sonnet-20241022, gemini-1.5-flash)
# AI_MODEL=

# API Keys
# At least one of these is required for AI tailoring
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Token Encryption
# Required for OAuth token storage (GitHub, LinkedIn, etc.)
# Generate one with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# NEVER commit this key to version control or share it publicly
TOKEN_ENCRYPTION_KEY=your_token_encryption_key_here_generate_with_python_command_above

# GitHub OAuth Configuration
# Required for GitHub OAuth integration
# Create OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
# Authentication mode: oauth (OAuth tokens) or cli (GitHub CLI)
GITHUB_AUTH_MODE=oauth

# CORS Origins (comma-separated list for production)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting Configuration
# Set to false to disable rate limiting (for development)
ENABLE_RATE_LIMITING=true
# Rate limits for different endpoints (format: <limit>/<period>)
RATE_LIMIT_PDF=10/minute
RATE_LIMIT_TAILOR=30/minute
RATE_LIMIT_VARIANTS=60/minute
