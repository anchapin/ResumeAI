# Resume API Environment Configuration

# Application Settings
DEBUG=false
APP_NAME=Resume API
APP_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000

# API Authentication
# Set to false to disable API key authentication (for development)
REQUIRE_API_KEY=true

# API Key Configuration - IMPORTANT: Keys should be hashed using bcrypt
# Hash your API keys using: python scripts/migrate_api_keys.py --keys "your_plaintext_key"
# You can also hash keys using the provided migration script: python scripts/migrate_api_keys.py --env-file .env

# Master API key for ResumeAI frontend (hashed or plaintext during migration)
# Example (plaintext): rai_1234567890abcdef1234567890abcdef
# Example (hashed): $2b$12$slYQmyNdGzin7olVN3p5Be7DlH.PKZbv5H8KnzzVgXXbVxzy86qke
MASTER_API_KEY=rai_1234567890abcdef1234567890abcdef

# Additional API keys for 3rd party developers (comma-separated, hashed or plaintext)
# IMPORTANT: For production, use hashed keys only
# Plaintext example: rai_xyz...,rai_abc...,rai_test_key...
# Hashed example: $2b$12$hash1...,$2b$12$hash2...,$2b$12$hash3...
# API_KEYS=rai_xyz...,rai_abc...,rai_test_key...

# JWT Authentication (for user accounts)
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration
# Options: openai, claude, gemini
AI_PROVIDER=openai
# Optional: Specify a custom model (e.g., gpt-4o-mini, claude-3-5-sonnet-20241022, gemini-1.5-flash)
# AI_MODEL=

# API Keys
# At least one of these is required for AI tailoring
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Origins (comma-separated list for production)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting Configuration
# Set to false to disable rate limiting (for development)
ENABLE_RATE_LIMITING=true
# Rate limits for different endpoints (format: <limit>/<period>)
RATE_LIMIT_PDF=10/minute
RATE_LIMIT_TAILOR=30/minute
RATE_LIMIT_VARIANTS=60/minute

# Stripe Configuration (for subscription billing)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Stripe Price IDs for subscription plans
# Create products and prices in Stripe Dashboard, then copy the price IDs
STRIPE_PRICE_ID_BASIC=price_basic_plan_id_here
STRIPE_PRICE_ID_PREMIUM=price_premium_plan_id_here

# Token Encryption (for OAuth token storage at rest)
# IMPORTANT: Generate a secure key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store this key securely in production. Do not commit to version control.
TOKEN_ENCRYPTION_KEY=your_token_encryption_key_here_generate_with_command_above

# GitHub OAuth Configuration

# GitHub OAuth App credentials (required)
# Register an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# LinkedIn OAuth Configuration (Optional)
# Register an OAuth App at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:5173/auth/linkedin/callback
