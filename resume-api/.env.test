# Test environment for rate limiting

# Application Settings
DEBUG=true
APP_NAME=Resume API
APP_VERSION=1.0.0

# Server Settings
HOST=0.0.0.0
PORT=8000

# API Authentication
REQUIRE_API_KEY=true
MASTER_API_KEY=rai_master_1234567890abcdef
API_KEYS=rai_test_key_1234567890,rai_test_key_0987654321

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=sk-test-key-for-testing-only

# Rate Limiting Configuration
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PDF=10/minute
RATE_LIMIT_TAILOR=30/minute
RATE_LIMIT_VARIANTS=60/minute

# JWT Configuration (for testing)
JWT_SECRET=test_jwt_secret_for_testing_only
