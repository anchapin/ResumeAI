{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "React: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "npm: dev"
    },
    {
      "name": "React: Firefox",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "npm: dev"
    },
    {
      "name": "Python: FastAPI (ResumeAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "resume-api.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "jinja": true,
      "justMyCode": true,
      "python": "/usr/local/bin/python3",
      "envFile": "${workspaceFolder}/resume-api/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "--", "--inspect-brk"],
      "console": "integratedTerminal",
      "env": {
        "CI": "true"
      },
      "autoAttachChildProcesses": true
    },
    {
      "name": "Debug Current Test File",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}", "--inspect-brk"],
      "console": "integratedTerminal",
      "env": {
        "CI": "true"
      }
    },
    {
      "name": "E2E Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["playwright", "test", "--headed"],
      "console": "integratedTerminal",
      "env": {
        "CI": "false"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": ["React: Chrome", "Python: FastAPI (ResumeAPI)"],
      "stopAll": true
    }
  ]
}
