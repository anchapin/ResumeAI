# Local Development Environment Variables
# Copy this file to .env.local and adjust values as needed
#
# Usage:
#   docker-compose -f docker-compose.local.yml up -d
#
# Or for manual development:
#   cp .env.local.example .env.local
#   # Then edit .env.local with your values

################################################################################
# FRONTEND CONFIGURATION
################################################################################

# API URL (Vite will use this)
VITE_API_URL=http://localhost:8000

# API Key (for local development - not required with REQUIRE_API_KEY=false)
RESUMEAI_API_KEY=rai_dev_key_1234567890abcdef

################################################################################
# BACKEND CONFIGURATION
################################################################################

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# AI Provider (at least one required)
AI_PROVIDER=openai
AI_MODEL=gpt-4o
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Claude
# AI_PROVIDER=claude
# AI_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_API_KEY=your_claude_api_key_here

# Alternative: Gemini
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# API Authentication (disable for local development)
MASTER_API_KEY=rai_dev_key_1234567890abcdef
REQUIRE_API_KEY=false

################################################################################
# DATABASE CONFIGURATION (for local development with Docker)
################################################################################

# PostgreSQL (provided by docker-compose.local.yml)
DATABASE_URL=postgresql://resumeai:resumeai_dev@localhost:5432/resumeai
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

################################################################################
# REDIS CONFIGURATION (for local development with Docker)
################################################################################

# Redis (provided by docker-compose.local.yml)
REDIS_URL=redis://localhost:6379/0
CACHE_BACKEND=redis

################################################################################
# LOGGING
################################################################################

LOG_LEVEL=INFO
LOG_FORMAT=text
