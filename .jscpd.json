{
  "threshold": 5,
  "minLines": 10,
  "minTokens": 70,
  "reporters": ["console", "html", "json", "xml"],
  "output": ".jscpd-report",
  "format": ["typescript", "javascript", "tsx", "jsx", "python"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/tests/**",
    "**/test_*.py",
    "**/*_test.py",
    "**/__pycache__/**",
    "**/resume-api/tests/**",
    "**/resume-api/templates/**",
    "**/resume-api/dashboards/**",
    "**/resume-api/migrations/**"
  ]
}
