################################################################################
# DOCKER ENVIRONMENT CONFIGURATION
#
# This file contains Docker-specific environment variables.
# Used when running in Docker containers via docker-compose.
# Copy this to .env in the project root:
#   cp .env.docker.example .env
#
################################################################################

## Docker Configuration
# Environment: development, staging, production
DOCKER_ENV=production
REGISTRY_URL=docker.io
IMAGE_TAG=latest

## Backend API
# API container name or service name
API_SERVICE_NAME=resume-api
# API port (internal container port)
API_PORT=8000

## Frontend
# Frontend container name or service name  
FRONTEND_SERVICE_NAME=resume-frontend
# Frontend port (internal container port)
FRONTEND_PORT=80
# Frontend HTTPS port
FRONTEND_HTTPS_PORT=443

## Database (if using database in future)
# DATABASE_HOST=postgres
# DATABASE_PORT=5432

## Redis (if using caching)
# REDIS_HOST=redis
# REDIS_PORT=6379

## Network Configuration
# Docker network name
DOCKER_NETWORK=resumeai-network

## Volume Configuration
# Persistent data volumes
# DATA_VOLUME=/var/lib/resumeai

## Logging
# Docker log driver: json-file, syslog, journald
LOG_DRIVER=json-file
LOG_OPTS=max-size=10m max-file=3
